<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — CitasApp</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@600;800&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="scanlines" aria-hidden="true"></div>

    <header class="cyber-nav">
        <div class="cyber-nav-inner">
            <a class="brand" asp-controller="Home" asp-action="Index">CITAS<span>//</span>APP</a>
            <nav class="nav-links">
                <a asp-controller="Paciente" asp-action="Index">Pacientes</a>
                <a asp-controller="Medico" asp-action="Index">Médicos</a>
                <a asp-controller="Cita" asp-action="Index">Agenda</a>
                <a asp-controller="Calculadora" asp-action="Index">Calculadora</a>
            </nav>
        </div>
    </header>

    <main class="cyber-main">
        @RenderBody()
    </main>

    <footer class="cyber-footer">
        <p>SYSTEM_2026 // CitasApp &middot; Arquitectura Hexagonal &middot; Puertos &amp; Adaptadores</p>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
